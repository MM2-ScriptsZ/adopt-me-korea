{
  "version": 2,
  "name": "adopt-me-korea",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/game.html",
      "dest": "/game.html"
    },
    {
      "src": "/proxy.js",
      "dest": "/proxy.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    }
  ]
}
